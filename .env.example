# Copy this file to .env.local and fill in your EmailJS values.
# .env.local is gitignored — never commit real keys.
# Get these from https://dashboard.emailjs.com/

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# SHA-256 hex hash of your admin passphrase.
# Generate: echo -n 'your-passphrase' | shasum -a 256
# If empty, /#/admin and /#/admin/prompt show 404.
VITE_ADMIN_PASSPHRASE_HASH=
